# Render Free + Supabase + Cloudinary ayarları

SECRET_KEY=buraya-cok-uzun-rastgele-bir-secret-key-yaz
ADMIN_USERNAME=admin
ADMIN_PASSWORD=buraya-guclu-admin-sifresi-yaz

FLASK_DEBUG=0
SESSION_COOKIE_SECURE=1
MAX_UPLOAD_MB=6
PYTHON_VERSION=3.11.9

# Supabase Postgres bağlantı adresi.
# Supabase Dashboard > Project Settings > Database > Connection string
# URL'nin sonuna gerekirse ?sslmode=require ekleyebilirsin.
DATABASE_URL=postgresql://postgres:PAROLA@HOST:5432/postgres?sslmode=require

# Cloudinary görsel yükleme bilgileri.
CLOUDINARY_CLOUD_NAME=cloud-name
CLOUDINARY_API_KEY=api-key
CLOUDINARY_API_SECRET=api-secret
CLOUDINARY_FOLDER=muhendisim

# Render Free'de /var/data kullanma.
# DATA_DIR, DB_PATH ve UPLOAD_DIR ekleme.
UPLOAD_URL_PREFIX=uploads
