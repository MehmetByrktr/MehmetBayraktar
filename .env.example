# Yayına çıkmadan önce bunları kesin değiştir.
SECRET_KEY=buraya-cok-uzun-rastgele-bir-secret-key-yaz

# İlk kurulumda admin oluşurken kullanılır.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=buraya-guclu-admin-sifresi-yaz

# Yayında 0 kalmalı.
FLASK_DEBUG=0

# HTTPS aktif olduktan sonra 1 yap.
SESSION_COOKIE_SECURE=1

# Görsel yükleme limiti, MB.
MAX_UPLOAD_MB=6

# Production persistence.
# Render için:
DATA_DIR=/var/data
UPLOAD_DIR=/var/data/uploads
DB_PATH=/var/data/site.db
UPLOAD_URL_PREFIX=uploads

# Lokal geliştirme için yukarıdakileri boş bırakabilir veya instance klasörü kullanabilirsin.
